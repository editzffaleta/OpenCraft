# OpenClaw gateway — Podman Quadlet (rootless)
# Installed by setup-podman.sh into opencraft's ~/.config/containers/systemd/
# {{OPENCLAW_HOME}} is replaced at install time.

[Unit]
Description=OpenClaw gateway (rootless Podman)

[Container]
Image=opencraft:local
ContainerName=opencraft
UserNS=keep-id
# Keep container UID/GID aligned with the invoking user so mounted config is readable.
User=%U:%G
Volume={{OPENCLAW_HOME}}/.opencraft:/home/node/.opencraft:Z
EnvironmentFile={{OPENCLAW_HOME}}/.opencraft/.env
Environment=HOME=/home/node
Environment=TERM=xterm-256color
PublishPort=18789:18789
PublishPort=18790:18790
Pull=never
Exec=node dist/index.js gateway --bind lan --port 18789

[Service]
TimeoutStartSec=300
Restart=on-failure

[Install]
WantedBy=default.target
