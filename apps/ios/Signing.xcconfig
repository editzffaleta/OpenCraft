// Default signing values for shared/repo builds.
// Auto-selected local team overrides live in .local-signing.xcconfig (git-ignored).
// Manual local overrides can go in LocalSigning.xcconfig (git-ignored).

#include "Config/Version.xcconfig"

OPENCRAFT_CODE_SIGN_STYLE = Manual
OPENCRAFT_DEVELOPMENT_TEAM = Y5PE65HELJ

OPENCRAFT_APP_BUNDLE_ID = ai.opencraft.client
OPENCRAFT_SHARE_BUNDLE_ID = ai.opencraft.client.share
OPENCRAFT_WATCH_APP_BUNDLE_ID = ai.opencraft.client.watchkitapp
OPENCRAFT_WATCH_EXTENSION_BUNDLE_ID = ai.opencraft.client.watchkitapp.extension
OPENCRAFT_ACTIVITY_WIDGET_BUNDLE_ID = ai.opencraft.client.activitywidget

OPENCRAFT_APP_PROFILE = ai.opencraft.client Development
OPENCRAFT_SHARE_PROFILE = ai.opencraft.client.share Development

// Keep local includes after defaults: xcconfig is evaluated top-to-bottom,
// so later assignments in local files override the defaults above.
#include? ".local-signing.xcconfig"
#include? "LocalSigning.xcconfig"
